---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import FAQPage from '@/components/sections/faq-page';

const title = "Peptide FAQ — Reconstitution, Dosing & Calculator Questions";
const description = "Answers to common questions about peptide reconstitution, bacteriostatic water, syringe dosing, storage, and using the mcgcalc peptide dosage calculator.";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is peptide reconstitution and why is it necessary?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Peptides are shipped as lyophilized (freeze-dried) powder to preserve stability. Reconstitution is the process of dissolving this powder with bacteriostatic water (BAC water) to create an injectable solution. Without reconstitution, accurate dosing is not possible."
      }
    },
    {
      "@type": "Question",
      "name": "How much bacteriostatic water should I add to my vial?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "There is no single correct volume — it depends on the peptide amount and your desired concentration. Common volumes are 1–3 mL. Adding more water makes each unit on the syringe deliver a smaller dose, which can improve dosing precision."
      }
    },
    {
      "@type": "Question",
      "name": "Can I use sterile water instead of bacteriostatic water?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Bacteriostatic water contains 0.9% benzyl alcohol, which inhibits bacterial growth and allows multi-dose use over several weeks. Sterile water lacks this preservative — if used, the entire vial should be consumed within 24 hours."
      }
    },
    {
      "@type": "Question",
      "name": "How long do reconstituted peptides remain stable?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "When reconstituted with bacteriostatic water and stored at 2–8°C (refrigerated), most peptides remain stable for 21–28 days. Avoid freezing reconstituted solutions."
      }
    },
    {
      "@type": "Question",
      "name": "What syringe size should I use for peptide injections?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Insulin syringes in 0.3 mL (30 units), 0.5 mL (50 units), or 1 mL (100 units) are standard. For doses under 30 units, a 0.3 mL syringe offers finer graduation marks and greater precision."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between units, IU, and mL?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "On an insulin syringe, 'units' refer to the graduation marks — a 100-unit syringe holds 1 mL, so 1 unit = 0.01 mL. IU (International Units) is a pharmacological measure of biological activity, not directly equivalent to syringe units."
      }
    },
    {
      "@type": "Question",
      "name": "How do I calculate the number of doses in a vial?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Divide the total peptide content (in mcg) by your dose per injection. For example, a 5 mg BPC-157 vial contains 5,000 mcg. At 250 mcg per dose, that yields 20 doses."
      }
    },
    {
      "@type": "Question",
      "name": "How should I store unreconstituted peptide vials?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Lyophilized peptides should be stored in a cool, dry place. Refrigeration (2–8°C) is ideal for long-term storage. Always check the manufacturer's storage recommendations."
      }
    },
    {
      "@type": "Question",
      "name": "Is mcgcalc free to use?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, completely free — no sign-ups required, no hidden fees. All calculations run entirely in your browser."
      }
    },
    {
      "@type": "Question",
      "name": "Does mcgcalc store my personal data?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. We don't collect any personal information. Saved calculations are stored locally in your browser using localStorage — nothing is ever sent to a server."
      }
    }
  ]
};
---

<DefaultLayout title={title} description={description} schema={schema}>
    <FAQPage client:only='react' />
</DefaultLayout>
