---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { PeptideCalculator } from '@/components/sections/peptide-calculator';

const title = "Peptide Dosage Calculator";
const description = "Calculate the exact injection volume for your peptide dose. Supports multiple peptides, different syringe sizes, and bacteriostatic water volumes.";
---

<DefaultLayout title={title} description={description}>
  <section class="py-16 px-4">
    <div class="max-w-2xl mx-auto text-center mb-10">
      <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-3">Peptide Dosage Calculator</h1>
      <p class="text-slate-500 dark:text-slate-400">
        Enter your peptide quantity, bacteriostatic water volume, and desired dose to instantly calculate the exact syringe units to draw.
      </p>
    </div>
    <PeptideCalculator client:load />
  </section>
</DefaultLayout>
