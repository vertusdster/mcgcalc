---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { IntranasalCalculator } from '@/components/sections/intranasal-calculator';

const title = "Intranasal Calculator — Peptide Nasal Spray Dosage Tool";
const description = "Accurate intranasal dosage calculations made simple. Calculate peptide per spray, sprays needed, and plan your nasal spray preparations with our free tool.";
---

<DefaultLayout title={title} description={description}>
  <section class="py-16 px-4">
    <div class="max-w-2xl mx-auto text-center mb-10">
      <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-3">
        Intranasal Calculator
      </h1>
      <p class="text-slate-500 dark:text-slate-400">
        Accurate intranasal dosage calculations made simple.
      </p>
    </div>
    <IntranasalCalculator client:load />
  </section>
</DefaultLayout>
