---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { UnitConverter } from '@/components/sections/unit-converter';

const title = "Unit Converter — ml, mg, uL, mcg Conversion Tool";
const description = "Easily convert between Milliliters (ml), Milligrams (mg), Microliters (uL), and Micrograms (mcg). Enter a value in any unit to instantly see the equivalent values.";
---

<DefaultLayout title={title} description={description}>
  <section class="py-4 md:py-16">
    <div class="max-w-2xl mx-auto text-center mb-10 hidden md:block">
      <h1 class="text-3xl font-bold text-foreground mb-3">
        Unit Converter
      </h1>
      <p class="text-muted-foreground">
        Easily convert between Milliliters (ml), Milligrams (mg), Microliters (uL), and Micrograms (mcg). Enter a value in any unit to instantly see the equivalent values in the other three units. Ideal for precise scientific and laboratory measurements.
      </p>
    </div>
    <div class="container">
      <UnitConverter client:load />
    </div>
  </section>
</DefaultLayout>
