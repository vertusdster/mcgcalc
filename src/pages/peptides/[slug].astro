---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { PeptideCalculator } from '@/components/sections/peptide-calculator';

export async function getStaticPaths() {
  const peptides = await getCollection('peptides');
  return peptides.map(peptide => ({
    params: { slug: peptide.id },
    props: peptide,
  }));
}

type Props = CollectionEntry<'peptides'>;
const peptide = Astro.props;
const { Content } = await render(peptide);

const title = `${peptide.data.name} Dosage Calculator — How Many Units to Draw`;
const description = peptide.data.description;
---

<DefaultLayout title={title} description={description}>
  <div class="py-12 md:py-20">
    <div class="container max-w-5xl">
      <div class="mb-4">
        <a href="/peptides" class="text-sm text-muted-foreground hover:text-[#11696f] transition-colors">
          ← All Peptides
        </a>
      </div>

      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2">
        {/* Article content */}
        <div class="order-2 lg:order-1">
          <div class="mb-2">
            <span class="rounded-full bg-[#11696f]/10 px-3 py-1 text-xs font-semibold text-[#11696f]">
              {peptide.data.category}
            </span>
          </div>
          <h1 class="mt-3 text-3xl font-bold tracking-tight md:text-4xl">
            {peptide.data.name} Dosage Calculator
          </h1>
          <article class="prose prose-slate dark:prose-invert mt-8 max-w-none">
            <Content />
          </article>
        </div>

        {/* Calculator column */}
        <div class="order-1 lg:order-2">
          <div class="sticky top-8">
            <p class="mb-3 text-sm font-semibold text-slate-500 uppercase tracking-wide">
              {peptide.data.name} Calculator
            </p>
            <PeptideCalculator client:load />
          </div>
        </div>
      </div>
    </div>
  </div>
</DefaultLayout>
