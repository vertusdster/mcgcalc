---
import { getCollection } from 'astro:content';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { SITE_TITLE } from '@/consts';

const peptides = await getCollection('peptides');

const categories = [...new Set(peptides.map(p => p.data.category))].sort();

const byCategory = categories.reduce((acc, cat) => {
  acc[cat] = peptides.filter(p => p.data.category === cat);
  return acc;
}, {} as Record<string, typeof peptides>);

const title = "Peptide List — Dosage Calculator for Every Peptide";
const description = "Browse our complete peptide database. Click any peptide to open its dedicated dosage calculator with pre-filled default values for syringe units, BAC water, and dose.";
---

<DefaultLayout title={title} description={description}>
  <section class="py-16 md:py-24">
    <div class="container max-w-5xl">
      <div class="mb-12 text-center">
        <h1 class="text-3xl font-bold tracking-tight md:text-4xl">Peptide Dosage Calculator List</h1>
        <p class="text-muted-foreground mt-3 text-lg">
          Select a peptide to open its dedicated calculator with pre-filled dosing parameters.
        </p>
      </div>

      {categories.map(category => (
        <div class="mb-12">
          <h2 class="mb-4 text-xl font-semibold tracking-tight border-b pb-2">{category}</h2>
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {byCategory[category].map(peptide => (
              <a
                href={`/peptides/${peptide.id}`}
                class="group rounded-xl border border-border/60 bg-card p-5 shadow-sm transition-all hover:border-[#3b82f6] hover:shadow-md"
              >
                <div class="flex items-start justify-between gap-2">
                  <h3 class="font-bold text-slate-800 dark:text-white group-hover:text-[#1d4ed8] transition-colors">
                    {peptide.data.name}
                  </h3>
                  <span class="shrink-0 rounded-full bg-[#1d4ed8]/10 px-2 py-0.5 text-xs font-medium text-[#1d4ed8]">
                    {peptide.data.category}
                  </span>
                </div>
                <p class="text-muted-foreground mt-2 text-sm line-clamp-2">
                  {peptide.data.description}
                </p>
                <div class="mt-3 flex gap-3 text-xs text-slate-400">
                  <span>Default dose: {peptide.data.defaultDose}mcg</span>
                  <span>·</span>
                  <span>Vial: {peptide.data.defaultVialSize}mg</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</DefaultLayout>
