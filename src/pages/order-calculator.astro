---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { OrderCalculator } from '@/components/sections/order-calculator';

const title = "Order Calculator — Plan Your Peptide Purchases";
const description = "This calculator helps you determine how many vials you'll need for your peptide protocol based on your dosage, frequency, and duration of use.";
---

<DefaultLayout title={title} description={description}>
  <section class="py-16 px-4">
    <div class="max-w-2xl mx-auto text-center mb-10">
      <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-3">
        Order Calculator
      </h1>
      <p class="text-slate-500 dark:text-slate-400">
        This calculator helps you determine how many vials you'll need for your peptide protocol based on your dosage, frequency, and duration of use.
      </p>
    </div>
    <OrderCalculator client:load />
  </section>
</DefaultLayout>
