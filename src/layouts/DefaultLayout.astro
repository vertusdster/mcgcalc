---
import BaseHead from '@/components/BaseHead.astro';
import { Font } from 'astro:assets';
import Footer from '@/components/sections/footer';
import Navbar from '@/components/sections/navbar';
import Banner from '@/components/sections/banner';

const { title, description, schema, noindex } = Astro.props;
---

<html lang="en">
    <head>
        <BaseHead title={title} description={description} schema={schema} noindex={noindex} />
        <Font cssVariable="--font-inter" preload />
        <Font cssVariable="--font-sans" preload />
        <Font cssVariable="--font-mono" preload />
        <Font cssVariable="--font-mona" preload />
    </head>
    <body class={`h-screen antialiased flex flex-col`}
    >
<Navbar currentPage={Astro.url.pathname} client:load />
        <main class="flex-1"><slot /></main>
        <Footer />
    </body>
</html>
