---
import BaseHead from "@/components/BaseHead.astro";
import { Font } from "astro:assets";
import Navbar from "@/components/sections/navbar";
import Footer from "@/components/sections/footer";

const { title, description } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-sans" preload />
    <Font cssVariable="--font-mono" preload />
    <Font cssVariable="--font-mona" preload />
  </head>
  <body class={`h-screen antialiased`}>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:rounded-md focus:bg-background focus:px-4 focus:py-2 focus:text-foreground focus:ring-2 focus:ring-ring focus:ring-offset-2 focus:ring-offset-background"
    >
      Skip to content
    </a>
    <Navbar client:load />
    <main id="main-content" tabindex="-1">
      <section class="mx-auto max-w-2xl px-4 py-16 md:py-28 lg:py-32">
        <article class="prose prose-lg dark:prose-invert">
          <slot />
        </article>
      </section>
    </main>
    <Footer />
  </body>
</html>
